{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp",
      "headers": {
        "Authorization": "Bearer {env:SUPABASE_ACCESS_TOKEN}"
      },
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
    },
    "github-intel": {
      "type": "local",
      "command": ["/home/maxime/repos/mcp-server-github-intel/.venv/bin/python", "/home/maxime/repos/mcp-server-github-intel/server.py"],
      "enabled": true
    },
    "git": {
      "type": "local",
      "command": ["uvx", "mcp-server-git"],
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": ["/home/maxime/.local/bin/github-mcp-server", "stdio"],
      "enabled": true
    },
    "context-mode": {
      "type": "local",
      "command": ["context-mode"]
    },
    "figma": {
      "type": "remote",
      "url": "https://mcp.figma.com/mcp",
      "enabled": true
    }
  },
  "plugin": ["context-mode","opencode-anthropic-oauth"]
}
